# webhook configuration, Must be a accessible from the internet
KUSO_WEBHOOK_URL=https://kusoXXXXXXXXXXXXX.loca.lt/api/repo/webhooks

KUBECONFIG_PATH=./kubeconfig
#KUBECONFIG_BASE64=$(cat ./kubeconfig | base64 -w 0)

KUSO_CONFIG_PATH=./config.yaml
KUSO_CONTEXT=kind-kuso-001
KUSO_NAMESPACE=sislelabs # needs to be created manually in the cluster, since the in cluster default is "kuso"
KUSO_SESSION_KEY=randomString
KUSO_CLUSTERISSUER=letsencrypt-prod
KUSO_BUILD_REGISTRY=kuso-registry-yourdomain.com/something

# KUSO_PROMETHEUS_ENDPOINT=http://kuso-prometheus-server # within cluster
KUSO_PROMETHEUS_ENDPOINT=http:/127.0.0.1:8080 # for local development
# kubectl port-forward svc/kuso-prometheus-server 8080:80 -n kuso

KUSO_AUDIT=false
KUSO_AUDIT_DB_PATH=./db
KUSO_AUDIT_LIMIT=1000

