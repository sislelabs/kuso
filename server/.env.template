PORT=2000
DEBUG=*.*
DATABASE_URL="file:../db/kuso.sqlite?mode=rwc&_journal=WAL&_busy_timeout=5000"
LOGLEVEL=verbose
NODE_ENV=production

KUSO_WEBHOOK_SECRET=mysecret

KUSO_AUTHENTICATION=false
JWT_SECRET="A long random string that should be kept secret"
JWT_EXPIRESIN=36000s



