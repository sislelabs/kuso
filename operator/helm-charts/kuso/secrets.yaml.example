apiVersion: v1
kind: Secret
metadata:
  name: kuso-secrets
type: Opaque
stringData:
    KUSO_WEBHOOK_SECRET: "mysecret_MAKE_IT_LONG"
    #UBERO_USERS: #DEPRECATED
    KUSO_ADMIN_USERNAME:
    KUSO_ADMIN_PASSWORD:
    KUSO_SESSION_KEY:
    KUBECONFIG_BASE64:
    GITHUB_PERSONAL_ACCESS_TOKEN:
    GITHUB_BASEURL:
    GITEA_PERSONAL_ACCESS_TOKEN:
    GITEA_BASEURL:
    GITLAB_PERSONAL_ACCESS_TOKEN:
    GITLAB_BASEURL:
    GOGS_PERSONAL_ACCESS_TOKEN:
    GOGS_BASEURL:
    BITBUCKET_USERNAME:
    BITBUCKET_APP_PASSWORD:
    GITHUB_CLIENT_SECRET:
    OAUTH2_CLIENT_ID:
    OAUTH2_CLIENT_SECRET: