# OS
.DS_Store
Thumbs.db

# Local agent runtime state. The .claude dir holds scheduled task
# lockfiles + skill caches that are workstation-specific.
.claude/scheduled_tasks.lock

# Editor
.vscode/
.idea/
*.swp
*.swo

# Node
node_modules/
dist/
# `build/` ignores stray go/npm build outputs, but the project's
# repo-tracked image sources live at build/{updater,backup}/Dockerfile
# and entrypoint.sh — so we anchor the ignore at the root and re-include
# the docker build sources explicitly.
/build/*
!/build/updater/
!/build/backup/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Go
*.exe
*.test
*.out
vendor/
bin/

# Env / secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Build outputs
coverage/
.next/
.nuxt/
.cache/

# Operator / k8s
kubeconfig
*.kubeconfig

# Local kind / dev
.kube/

# Generated frontend dist (output of scripts/build-frontend.sh, embedded
# into the Go binary at build time; the .gitkeep is what we track).
# The earlier `dist/` rule above ignores the directory's contents; we
# re-include it here, then negate the .gitkeep so the placeholder is
# tracked.
!server-go/internal/web/dist/
server-go/internal/web/dist/*
!server-go/internal/web/dist/.gitkeep
