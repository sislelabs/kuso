{
  "v1alpha1": {
    "description": "KusoEnvironment is one running instance of a KusoService — production or preview.",
    "properties": {
      "apiVersion": {
        "type": "string"
      },
      "kind": {
        "type": "string"
      },
      "metadata": {
        "type": "object"
      },
      "spec": {
        "properties": {
          "additionalHosts": {
            "description": "Extra hostnames routed to this env's pod. Server populates this from KusoService.spec.domains so custom domains attach without losing the auto-generated host.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "autoscaling": {
            "properties": {
              "enabled": {
                "default": false,
                "type": "boolean"
              },
              "maxReplicas": {
                "default": 5,
                "type": "integer"
              },
              "minReplicas": {
                "default": 1,
                "type": "integer"
              },
              "targetCPUUtilizationPercentage": {
                "default": 70,
                "type": "integer"
              }
            },
            "type": "object"
          },
          "branch": {
            "default": "main",
            "type": "string"
          },
          "clusterIssuer": {
            "default": "letsencrypt-prod",
            "type": "string"
          },
          "command": {
            "description": "argv override; only used when runtime == \"worker\".",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "envFromSecrets": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "envVars": {
            "items": {
              "type": "object",
              "x-kubernetes-preserve-unknown-fields": true
            },
            "type": "array"
          },
          "host": {
            "type": "string"
          },
          "image": {
            "properties": {
              "pullPolicy": {
                "default": "IfNotPresent",
                "type": "string"
              },
              "repository": {
                "type": "string"
              },
              "tag": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "ingressClassName": {
            "default": "traefik",
            "type": "string"
          },
          "internal": {
            "default": false,
            "description": "When true, skip the Ingress entirely. Service still exists for in-cluster DNS access; no public domain or TLS. Mirrors KusoService.spec.internal.",
            "type": "boolean"
          },
          "kind": {
            "default": "production",
            "enum": [
              "production",
              "preview"
            ],
            "type": "string"
          },
          "placement": {
            "description": "Inherits the parent service placement so the env-helm chart can render nodeSelector + topologySpread. Pruning was the v0.7.x silent-data-loss bug — schema now covers what server-go writes.",
            "properties": {
              "labels": {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              },
              "nodes": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            },
            "type": "object"
          },
          "port": {
            "format": "int32",
            "type": "integer"
          },
          "project": {
            "type": "string"
          },
          "pullRequest": {
            "properties": {
              "headRef": {
                "type": "string"
              },
              "number": {
                "type": "integer"
              }
            },
            "type": "object"
          },
          "replicaCount": {
            "default": 1,
            "type": "integer"
          },
          "resources": {
            "type": "object",
            "x-kubernetes-preserve-unknown-fields": true
          },
          "runtime": {
            "description": "Mirrors KusoService.spec.runtime so the env helm chart can specialise (e.g. workers skip Service/Ingress/probes).",
            "type": "string"
          },
          "secretsRev": {
            "type": "string"
          },
          "service": {
            "type": "string"
          },
          "sleep": {
            "properties": {
              "enabled": {
                "default": false,
                "type": "boolean"
              }
            },
            "type": "object"
          },
          "tlsEnabled": {
            "default": true,
            "type": "boolean"
          },
          "ttl": {
            "properties": {
              "expiresAt": {
                "format": "date-time",
                "type": "string"
              }
            },
            "type": "object"
          },
          "volumes": {
            "description": "Persistent volumes to mount into the env's pod. Same shape as KusoService.spec.volumes; declared explicitly so the apiserver doesn't prune them.",
            "items": {
              "properties": {
                "accessModes": {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                "mountPath": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "size": {
                  "type": "string"
                },
                "storageClass": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "type": "array"
          }
        },
        "required": [
          "project",
          "service"
        ],
        "type": "object"
      },
      "status": {
        "type": "object",
        "x-kubernetes-preserve-unknown-fields": true
      }
    },
    "type": "object"
  }
}
