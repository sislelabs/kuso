{
  "v1alpha1": {
    "description": "KusoBuild is one build attempt. The operator renders a kaniko Job that clones the repo, builds the image, and pushes it to the in-cluster registry.",
    "properties": {
      "apiVersion": {
        "type": "string"
      },
      "kind": {
        "type": "string"
      },
      "metadata": {
        "type": "object"
      },
      "spec": {
        "properties": {
          "auth": {
            "properties": {
              "registry": {
                "type": "string"
              },
              "secretName": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "branch": {
            "type": "string"
          },
          "buildArgs": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "Build args passed to the build as --build-arg KEY=VAL (dockerfile ARG inputs). Mirrored from the service spec.",
            "type": "object"
          },
          "buildEnv": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "Service env vars resolved to literals, baked into the image at build time (ENV-after-FROM). Set by the server from the service's envVars (secretKeyRefs resolved server-side). For apps that read env during build (Prisma, Next.js NEXT_PUBLIC_*). Values bake into image layers.",
            "type": "object"
          },
          "buildpacks": {
            "type": "object",
            "x-kubernetes-preserve-unknown-fields": true
          },
          "cache": {
            "properties": {
              "pvcName": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "dockerfile": {
            "description": "Dockerfile filename (relative to repo.path) for strategy=dockerfile. Empty defaults to \"Dockerfile\".",
            "type": "string"
          },
          "done": {
            "default": false,
            "type": "boolean"
          },
          "dryRun": {
            "default": false,
            "type": "boolean"
          },
          "githubInstallationId": {
            "format": "int64",
            "type": "integer"
          },
          "image": {
            "properties": {
              "repository": {
                "type": "string"
              },
              "tag": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "project": {
            "type": "string"
          },
          "publicEnv": {
            "description": "Env var names baked as __KUSO_RUNTIME_\u003cKEY\u003e__ sentinels at build, substituted at pod start. Mirrored from the service.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "ref": {
            "type": "string"
          },
          "registry": {
            "properties": {
              "allowInsecure": {
                "type": "boolean"
              },
              "cacheRepo": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "repo": {
            "properties": {
              "path": {
                "default": ".",
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "resources": {
            "properties": {
              "limits": {
                "properties": {
                  "cpu": {
                    "type": "string"
                  },
                  "memory": {
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "requests": {
                "properties": {
                  "cpu": {
                    "type": "string"
                  },
                  "memory": {
                    "type": "string"
                  }
                },
                "type": "object"
              }
            },
            "type": "object"
          },
          "service": {
            "type": "string"
          },
          "static": {
            "type": "object",
            "x-kubernetes-preserve-unknown-fields": true
          },
          "strategy": {
            "default": "dockerfile",
            "enum": [
              "dockerfile",
              "nixpacks",
              "buildpacks",
              "static"
            ],
            "type": "string"
          }
        },
        "required": [
          "project",
          "service",
          "ref"
        ],
        "type": "object"
      },
      "status": {
        "type": "object",
        "x-kubernetes-preserve-unknown-fields": true
      }
    },
    "type": "object"
  }
}
